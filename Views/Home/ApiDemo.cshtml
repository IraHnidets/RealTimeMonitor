@{
    ViewData["Title"] = "REST API Demo";
}

<h4><i class="bi bi-braces text-warning"></i> REST API — Інтерактивний тестер</h4>
<p class="text-muted">Відправляйте запити до API та переглядайте відповіді сервера.</p>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">Доступні ендпоінти</div>
            <div class="list-group list-group-flush" id="endpointList">
                <button class="list-group-item list-group-item-action bg-transparent text-light border-secondary" onclick="call('GET', '/api/data/status')">
                    <span class="badge bg-success me-2">GET</span> /api/data/status
                </button>
                <button class="list-group-item list-group-item-action bg-transparent text-light border-secondary" onclick="call('GET', '/api/data/sensors/latest')">
                    <span class="badge bg-success me-2">GET</span> /api/data/sensors/latest
                </button>
                <button class="list-group-item list-group-item-action bg-transparent text-light border-secondary" onclick="call('GET', '/api/data/sensors/history?count=5')">
                    <span class="badge bg-success me-2">GET</span> /api/data/sensors/history?count=5
                </button>
                <button class="list-group-item list-group-item-action bg-transparent text-light border-secondary" onclick="call('GET', '/api/data/alerts')">
                    <span class="badge bg-success me-2">GET</span> /api/data/alerts
                </button>
                <button class="list-group-item list-group-item-action bg-transparent text-light border-secondary" onclick="call('POST', '/api/data/simulation/toggle')">
                    <span class="badge bg-warning text-dark me-2">POST</span> /api/data/simulation/toggle
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span id="reqLabel">Оберіть ендпоінт</span>
                <span id="reqTime" class="text-muted small"></span>
            </div>
            <div class="card-body p-0">
                <pre id="apiResult" style="min-height:350px;margin:0;border:none;">Натисніть на ендпоінт зліва...</pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function call(method, url) {
            document.getElementById('reqLabel').textContent = `${method} ${url}`;
            document.getElementById('apiResult').textContent = 'Завантаження...';
            const start = Date.now();
            const res = await fetch(url, { method });
            const ms = Date.now() - start;
            const data = await res.json();
            document.getElementById('apiResult').textContent = JSON.stringify(data, null, 2);
            document.getElementById('reqTime').textContent = `${res.status} • ${ms}ms`;
        }
    </script>
}